{
  "name": "yaket",
  "version": "0.1.0",
  "description": "TypeScript port of the YAKE keyword extraction core pipeline",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "yaket": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "benchmark": "tsx scripts/benchmark.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "yake",
    "keyword-extraction",
    "nlp",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "fast-check": "^4.3.0",
    "esbuild": "^0.25.9",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
