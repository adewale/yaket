{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "checkers": [],
  "reporters": ["clear-text", "json"],
  "mutate": [
    "src/similarity.ts",
    "src/SingleWord.ts",
    "src/ComposedWord.ts",
    "src/KeywordExtractor.ts"
  ],
  "coverageAnalysis": "perTest",
  "concurrency": 4,
  "thresholds": {
    "high": 90,
    "low": 85,
    "break": 85
  },
  "vitest": {
    "configFile": "vitest.config.ts"
  }
}
